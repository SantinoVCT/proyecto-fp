{% extends 'base.html.twig' %}

{% block title %}Info. del Carrito de {{ bd_carrito.Usuario.nombre }}. Producto: {{ bd_carrito.Producto.nombre }}
{% endblock %}

{% block body %}
	{% include 'partials/navbar.html.twig' %}
	<div class="mx-4 my-2">
		<a href="{{ path('app_carrito_index') }}" class="btn btn-light border-black mx-1">
			Volver
		</a>
		<a href="{{path('app_carrito_edit', {id: bd_carrito.id})}}" class="btn btn-light border-info mx-1">
			Editar
		</a>
		<form method="post" action="{{ path('app_carrito_delete', {'id': bd_carrito.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');" class="btn m-0 p-0">
			<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ bd_carrito.id) }}">
			<button class="btn btn-light border-danger mx-1">Borrar</button>
		</form>
	</div>
	<div class="overflow-hidden relative py-3 px-2 m-5"> 
		
		<div class="row mb-4">
			<div class="col">
				<img src="{{ asset('uploads/images/' ~ bd_carrito.Producto.Imagen) }}" alt="{{ bd_carrito.Producto.Nombre }}" class="img-fluid my-2" style="max-height: 300px; object-fit: contain;">
			</div>
			<div class="col">
				<h1 class="text-4xl font-bold mb-4">{{ bd_carrito.Producto.Nombre }}</h1>
				<p class="mx-2 text-secondary">Categoria:
					{{ bd_carrito.Producto.Categoria.Nombre }}</p>
				<p class="mx-2">Precio:
					<b class="precio">{{ bd_carrito.Producto.Precio }}€</b>
				</p>
				<div class="rounded border border-gry p-3 mt-4">
					<h3>Detalles del Carrito</h3>
					<p class="mx-2"> Producto en el carrito de <b> {{ bd_carrito.Usuario.nombre }}</b></p>
					<p class="mx-2"> Cantidad en el carrito: <b> {{ bd_carrito.Cantidad }}</b></p>
				</div>
			</div>
		</div>
	</div>
	{% include 'partials/footer.html.twig' %}
{% endblock %}
