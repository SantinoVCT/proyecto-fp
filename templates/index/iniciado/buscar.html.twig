{% extends 'base.html.twig' %}

{% block title %}PC Gaminng
{% endblock %}

{% block body %}
	{% include 'partials/navbar_1.html.twig' %}
	<main class="container-fluid px-3 pt-3 pb-5 mb-5" style="min-height:80vh;">
		<h2 class="mb-4">Resultados de búsqueda de: "{{ busqueda }}"</h2>
		<div class="row g-3 row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-5 justify-content-start">
			{% if productos %}
				{% for producto in productos %}
					<div class="col">
						<a href="{{ path('producto_online', {id: producto.id}) }}" class="d-flex flex-column h-100 bg-white p-3 btn btn-light rounded shadow text-start py-4 border border-gry">
							<div>
								<h4>{{ producto.Nombre }}</h4>
								<p>{{ producto.Descripcion|slice(0,100) }}...</p>
								{% if producto.Descuento %}
									<p>
										Precio: 
										<b class="precio">{{ (producto.Precio *(1-(producto.Descuento/100)))| number_format(2) }}€</b> 
										<b class="descuento rounded px-2 mx-2"> {{ producto.Descuento }}% </b>
									</p>
								{% else %}
									<p>
										Precio: <b class="precio">{{ producto.Precio }}€</b>
									</p>
								{% endif %}
							</div>
							<div class="mt-auto d-flex justify-content-center align-items-center">
								<img src="{{ asset('uploads/images/' ~ producto.Imagen) }}" alt="{{ producto.Nombre }}" class="img-fluid my-2" style="max-height: 75px; object-fit: contain;">
							</div>
						</a>
					</div>
				{% endfor %}
			{% else %}
				<div class="d-flex flex-column bg-white p-3 btn btn-light rounded shadow text-center mx-5 py-4 border border-gry">
					No se encontraron productos para "{{ busqueda }}".
				</div>
			{% endif %}
		</div>
	</main>
	<div class="row g-3 justify-content-center m-0 p-3 destacado-bg">
		<div class="mx-2 px-4 col-12">
			<h2 class="text-center my-3">PRODUCTOS DESTACADOS</h2>
		</div>
		{% for destacado in destacados|slice(0, 5)  %}
			<div class=" bg-white p-3 rounded shadow text-center col-12 col-sm-6 col-md-4 col-lg-2 mx-2 py-4 border border-gry">
				<h4>{{ destacado.Nombre }}</h4>
				<img src="{{ asset('uploads/images/' ~ destacado.Imagen) }}" alt="{{ destacado.Nombre }}" class="img-fluid my-2" style="max-height: 150px; object-fit: contain;">
				<p>{{ destacado.Descripcion|slice(0,100) }}...</p>
				{% if destacado.Descuento %}
					<p class="mx-2">
						Precio:
						<b class="precio">{{ (destacado.Precio *(1-(destacado.Descuento/100)))| number_format(2) }}€</b>
						<b class="descuento rounded px-2 mx-2">
							{{ destacado.Descuento }}%
						</b>
					</p>
				{% else %}
					<p class="mx-2">
						Precio:
						<b class="precio">{{ destacado.Precio }}€</b>
					</p>
				{% endif %}
				<div class="flex justify-center my-3">
					<a href="{{ path('producto_online', {id: destacado.id}) }}" class="btn btn-light border-black" style="width: 75px">
						Ver
					</a>
					<a href="{{ path('add_carrito', {id: destacado.id}) }}" class="btn btn-light border-black" style="width: 75px">
						Añadir
					</a>
				</div>
			</div>
		{% endfor %}
	</div>
	{% include 'partials/footer.html.twig' %}
{% endblock %}
