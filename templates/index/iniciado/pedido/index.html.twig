{% extends 'base.html.twig' %}

{% block title %}Mis Pedidos
{% endblock %}

{% block body %}
	{% include 'partials/navbar.html.twig' %}

	<main class="container py-4 mb-5">
		<div class="container mx-auto px-3">
			<h1 class="text-4xl font-bold mb-4">Informacion del Pedido</h1>

			<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3 my-3">
				{% if carritos is empty %}
					<div class="col">
						<div class="bg-white rounded shadow overflow-hidden relative p-3">
							<div class="font-bold h5">Pedidos no encontrados</div>
							<p class="text-gray-700 mb-0">
								No hay pedidos en la base de datos.
							</p>
						</div>
					</div>
				{% else %}
					{% for pedido in pedidos %}
						<div class="col p-0">
							<div class="pedido-cart d-flex flex-column h-100 bg-white p-3 btn btn-light rounded shadow text-center mx-1 py-4 border border-gry text-decoration-none text-reset">
								<button class="btn btn-link nav-link dropdown-toggle d-flex align-items-center p-0" id="pedidoDropdown{{ pedido.id }}" data-bs-toggle="dropdown" aria-expanded="false">
		                    		<h4 class="mx-2">Pedido: {{ pedido.codigo }}</h4>
		                		</button>
									<p class="mx-2">Fecha de compra: {{ pedido.fecha.format('d-m-Y') }}</p>
									<h5 class="precio"> Estado: {{ pedido.estado == 0 ? 'Preparando' : pedido.Estado == 1 ? 'En Reparto' : 'Enviado'  }}</h5>
								<br>
								<div class="dropdown-menu dropdown-menu-end pedido-dropdown-menu " style="overflow-y:auto; max-height: 300px; max-width: 350px;" aria-labelledby="pedidoDropdown{{ pedido.id }}">
				                    <div class="flex-column">
										{% for pProducto in pedidoProductos %}
				                    	    {% if pProducto.CodigoPedidoRelacion.id == pedido.id %}
				                    	        <div class="col-1" style="min-width: 300px;  max-height: 300px;" >
													<div class="d-flex flex-column h-100 bg-white p-3 bg-white rounded shadow text-start py-4 border border-gry">
														<div>
															<h4>{{ pProducto.Producto.Nombre }}</h4>
															<img src="{{ asset('uploads/images/' ~ pProducto.Producto.Imagen) }}" alt="{{ pProducto.Producto.Nombre }}" class="img-fluid my-2" style="max-height: 150px; object-fit: contain;">
															<h6>Cantidad: {{ pProducto.Cantidad }}
														</div>
													</div>
												</div>
				                    	    {% endif %}
				                    	{% endfor %}
									</div>
				                </div>
							</div>
						</div>
					{% endfor %}
				{% endif %}
			</div>

			<div class="d-flex justify-content-center mt-4">
				<nav aria-label="Paginacion pedidos">
					<ul class="pagination" id="productPagination"></ul>
				</nav>
			</div>
		</div>
	</main>

	<script>
		document.addEventListener('DOMContentLoaded', function () {
			const items = Array.from(document.querySelectorAll('.row .col'));
			const itemsPerPage = 8;
			const paginationEl = document.getElementById('productPagination');
			if (! paginationEl) 
				return;


			const productItems = items.filter(el => el.closest('.row') !== null && el.querySelector('.pedido-cart'));
			const totalItems = productItems.length;
			const totalPages = Math.max(1, Math.ceil(totalItems / itemsPerPage));
			let currentPage = 1;

			function showPage(page) {
				currentPage = page;
				productItems.forEach((el, idx) => {
					const pageIndex = Math.floor(idx / itemsPerPage) + 1;
					el.style.display = (pageIndex === page) ? '' : 'none';
				});
				renderPagination();
			}

			function renderPagination() {
				paginationEl.innerHTML = '';

				function makeItem(label, page, disabled, active) {
					const li = document.createElement('li');
					li.className = 'page-item' + (
					disabled ? ' disabled' : ''
					) + (active ? ' active' : '');
					const a = document.createElement('a');
					a.className = 'page-link';
					a.href = '#';
					a.innerText = label;
					a.addEventListener('click', function (e) {
						e.preventDefault();
						if (! disabled) 
						showPage(page);
					});
					li.appendChild(a);
					return li;
				}

				paginationEl.appendChild(makeItem('«', Math.max(1, currentPage - 1), currentPage === 1, false));
				for (let p = 1; p <= totalPages; p++) {
					paginationEl.appendChild(makeItem(p, p, false, p === currentPage));
				}
				paginationEl.appendChild(makeItem('»', Math.min(totalPages, currentPage + 1), currentPage === totalPages, false));
			}

			if (totalPages > 1) {
				showPage(1);
			} else {
				productItems.forEach(el => el.style.display = '');
			}
		});
	</script>

