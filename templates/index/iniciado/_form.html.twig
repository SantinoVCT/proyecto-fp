{{ form_start(
    form, 
    {'attr': {
        'novalidate': 'novalidate',
        'data-turbo': 'false'
        }}) 
}}
    <div style="display:flex; align-items:center;">
        <label for="{{ form.Nombre.vars.id }}" style="margin-right:8px;">Buscar: </label>
        {{ form_widget(form.Nombre, {'attr': {'class': 'form-control my-3', 'style':'flex:1'}}) }}
        <button class="btn btn-primary" style="margin-left:8px;">{{ button_label|default('🔍') }}</button>
    </div>

    {{ form_widget(form) }}
    
{{ form_end(form) }}
