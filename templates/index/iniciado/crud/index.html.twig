{% extends 'base.html.twig' %}

{% block title %}Base de Datos
{% endblock %}

{% block body %}
	{% include 'partials/navbar.html.twig' %}
	{% for message in app.flashes('error') %}
		<div class="alert alert-danger">
			{{ message }}
		</div>
	{% endfor %}

	<main class="container-fluid px-3 py-4">
		<div class="row g-3 justify-content-center px-5">
			{% if mostrarBotonAdmin %}
				<div class="col-xs-5 col-sm-5 col-md-5 col-lg-5 h-100">
					<a class="btn btn-light w-100 h-100 d-flex flex-column align-items-center justify-content-center text-decoration-none border-black" href="{{ path('app_usuario_index') }}">
						<img class="img-fluid mb-2" style="max-width: 100px;" src="https://cdn-icons-png.flaticon.com/512/1077/1077063.png" alt="Usuario">
						<span>Usuario</span>
					</a>
				</div>
			{% endif %}

			<div class="col-xs-5 col-sm-5 col-md-5 col-lg-5 h-100">
				<a class="btn btn-light w-100 h-100 d-flex flex-column align-items-center justify-content-center text-decoration-none border-black" href="{{ path('app_categoria_index') }}">
					<img class="img-fluid mb-2" style="max-width: 100px;" src="https://cdn-icons-png.flaticon.com/512/5665/5665189.png" alt="Categoria">
					<span>Categoria</span>
				</a>
			</div>
			<div class="col-xs-5 col-sm-5 col-md-5 col-lg-5 h-100">
				<a class="btn btn-light w-100 h-100 d-flex flex-column align-items-center justify-content-center text-decoration-none border-black" href="{{ path('app_producto_index') }}">
					<img class="img-fluid mb-2" style="max-width: 100px;" src="https://cdn-icons-png.flaticon.com/512/1170/1170679.png" alt="Producto">
					<span>Producto</span>
				</a>
			</div>
			<div class="col-xs-5 col-sm-5 col-md-5 col-lg-5 h-100">
				<a class="btn btn-light w-100 h-100 d-flex flex-column align-items-center justify-content-center text-decoration-none border-black" href="{{ path('app_carrito_index') }}">
					<img class="img-fluid mb-2" style="max-width: 100px;" src="https://cdn-icons-png.flaticon.com/512/4305/4305700.png" alt="Carrito">
					<span>Carrito</span>
				</a>
			</div>
			{# <div class="col-xs-5 col-sm-5 col-md-5  col-lg-5 h-100">
				<a class="btn btn-light w-100 h-100 d-flex flex-column align-items-center justify-content-center text-decoration-none border-black" href="{{ path('app_pedidos_index') }}">
					<img class="img-fluid mb-2" style="max-width: 100px;" src="https://cdn-icons-png.flaticon.com/512/814/814995.png" alt="Pedidos">
					<span>Pedidos</span>
				</a>
			</div> #}
			<div class="col-xs-5 col-sm-5 col-md-5 col-lg-5 h-100">
				<a class="btn btn-light w-100 h-100 d-flex flex-column align-items-center justify-content-center text-decoration-none border-black" href="{{ path('app_codigo_pedidos_index') }}">
					<img class="img-fluid mb-2" style="max-width: 100px;" src="https://img.icons8.com/?size=100&id=649Wi2iCZ71j&format=png&color=000000" alt="Pedidos">
					<span>Codigo Pedidos</span>
				</a>
			</div>
			<div class="col-xs-5 col-sm-5 col-md-5 col-lg-5 h-100">
				<a class="btn btn-light w-100 h-100 d-flex flex-column align-items-center justify-content-center text-decoration-none border-black" href="{{ path('app_anuncio_index') }}">
					<img class="img-fluid mb-2" style="max-width: 100px;" src="https://img.icons8.com/?size=100&id=WCf4kcsJ1PWW&format=png&color=000000" alt="Pedidos">
					<span>Anuncio</span>
				</a>
			</div>
		</div>
	</main>
	{% include 'partials/footer.html.twig' %}
{% endblock %}
