{% extends 'base.html.twig' %}

{% block title %}Producto
{% endblock %}

{% block body %}
	{% include 'partials/navbar.html.twig' %}

	<main class="container-fluid p-0 pb-4">
		<div class="overflow-hidden relative py-3 px-2 m-5">
			<div class="row mb-4">
				<div class="col">
					<img src="{{ asset('uploads/images/' ~ producto.Imagen) }}" alt="{{ producto.Nombre }}" class="img-fluid my-2" style="max-height: 300px; object-fit: contain;">
				</div>
				<div class="col">
					<h1 class="text-4xl font-bold mb-4">{{ producto.Nombre }}</h1>
					<p class="mx-2 text-secondary">Categoria:
						{{ producto.Categoria.Nombre }}</p>
					{% if producto.Descuento %}
						<p class="mx-2">
							Precio: <del>{{ producto.Precio }}</del>€  
							<b class="precio">{{ (producto.Precio *(1-(producto.Descuento/100)))| number_format(2) }}€</b> 
							<b class="descuento rounded px-2 mx-2"> {{ producto.Descuento }}% </b>
						</p>
					{% else %}
						<p class="mx-2">
							Precio: <b class="precio">{{ producto.Precio }}€</b>
						</p>
					{% endif %}
					<a href="{{ path('add_carrito', {id: producto.id}) }}" class="btn btn-light border-black mx-3">
						Añadir
					</a>
				</div>
			</div>
			<div class="text-xl font-bold mx-2">
				<h2 class="text-3xl mx-2">Descripcion</h2>
				<p class="mx-2">{{ producto.Descripcion }}</p>
			</div>
			<div class="text-xl font-bold mx-2">
				<h2 class="text-3xl mx-2">Caracteristicas</h2>
				<p class="mx-2">{{ producto.Caracteristicas }}</p>
			</div>

			<div class="text-xl font-bold mx-2">
				<h2 class="text-3xl mx-2">Requisitos</h2>
				{% if producto.Requisitos is empty%}
					<p class="mx-2">No hay requisitos disponibles para este producto.</p>
				{% else %}
					<p class="mx-2">{{ producto.Requisitos }}</p>

				{% endif %}
			</div>
		</div>
		<div class="row g-3 justify-content-center m-0 mb-5 p-3 destacado-bg">
			<div class=" mx-2 px-4 col-12">
				<h2 class="text-center my-3">PRODUCTOS DESTACADOS</h2>
			</div>
			{% for destacado in destacados|slice(0, 5)  %}
				{% if destacado.id != producto.id %}
					<a href="{{ path('producto_online', {id: destacado.id}) }}" class=" bg-white p-3 btn btn-light rounded shadow text-center col-12 col-sm-6 col-md-4 col-lg-2 mx-2 py-4 border border-gry">
						<h4>{{ destacado.Nombre }}</h4>
						<img src="{{ asset('uploads/images/' ~ destacado.Imagen) }}" alt="{{ destacado.Nombre }}" class="img-fluid my-2" style="max-height: 150px; object-fit: contain;">
						<p>{{ destacado.Descripcion|slice(0,100) }}...</p>
						<h5 class="precio">{{ destacado.Precio }}€</h5>
					</a>
				{% endif %}
			{% endfor %}
		</div>
	</main>
	{% include 'partials/footer.html.twig' %}
{% endblock %}
