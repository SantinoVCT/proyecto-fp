{% extends 'base.html.twig' %}

{% block title %}Info.
	{{ producto.Nombre }}
{% endblock %}

{% block body %}
	{% include 'partials/navbar.html.twig' %}
	<div class="mx-4 my-2">
		<a href="{{ path('app_producto_index') }}" class="btn btn-light border-black mx-1">
			Volver
		</a>
		<a href="{{path('app_producto_edit', {id: producto.id})}}" class="btn btn-light border-info mx-1">
			Editar
		</a>
		<form method="post" action="{{ path('app_producto_delete', {'id': producto.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');" class="btn m-0 p-0">
			<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ producto.id) }}">
			<button class="btn btn-light border-danger mx-1">Borrar</button>
		</form>
	</div>
	<h2 class="mx-4">Vista previa</h2>
	<div class="overflow-hidden relative py-3 px-2 m-5"> 
		
		<div class="row mb-4">
			<div class="col">
				<img src="{{ asset('uploads/images/' ~ producto.Imagen) }}" alt="{{ producto.Nombre }}" class="img-fluid my-2" style="max-height: 300px; object-fit: contain;">
			</div>
			<div class="col">
				<h1 class="text-4xl font-bold mb-4">{{ producto.Nombre }}</h1>
				<p class="mx-2 text-secondary">Categoria:
					{{ producto.Categoria.Nombre }}</p>
				<p class="mx-2">Precio:
					<b class="precio">{{ producto.Precio }}€</b>
				</p>
				<a href="" class="btn btn-light border-black mx-3">
					Añadir
				</a>
				<div class="rounded border border-gry p-3 mt-4">
					<h3>Detalles del Ocultos</h3>
					<p class="mx-2"> Disponible: <b> {{ producto.Disponible ? 'Sí' : 'No' }}</b></p>
					<p class="mx-2"> Fecha de Creacion: <b> {{ producto.FechaCreada.format('Y-m-d H:i:s') }}</b></p>
					<p class="mx-2"> Fecha Actualizada: <b> {{ producto.FechaUpdate ? producto.FechaUpdate.format('Y-m-d H:i:s') : 'N/A' }}</b></p>
				</div>
			</div>
		</div>
		<div class="text-xl font-bold mx-2">
			<h2 class="text-3xl mx-2">Descripcion</h2>
			<p class="mx-2">{{ producto.Descripcion }}</p>
		</div>
		<div class="text-xl font-bold mx-2">
			<h2 class="text-3xl mx-2">Caracteristicas</h2>
			<p class="mx-2">{{ producto.Caracteristicas }}</p>
		</div>

		<div class="text-xl font-bold mx-2">
			<h2 class="text-3xl mx-2">Requisitos</h2>
			{% if producto.Requisitos is empty%}
				<p class="mx-2">No hay requisitos disponibles para este producto.</p>
			{% else %}
				<p class="mx-2">{{ producto.Requisitos }}</p>

			{% endif %}
		</div>
	</div>
</div>{% endblock %}
