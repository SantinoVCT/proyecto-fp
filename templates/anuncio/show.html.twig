{% extends 'base.html.twig' %}

{% block title %}Info.
	{{ anuncio.Nombre }}
{% endblock %}

{% block body %}
	{% include 'partials/navbar.html.twig' %}
	<div class="mx-4 my-2">
		<a href="{{ path('app_anuncio_index') }}" class="btn btn-light border-black mx-1">
			Volver
		</a>
		<a href="{{path('app_anuncio_edit', {id: anuncio.id})}}" class="btn btn-light border-info mx-1">
			Editar
		</a>
		<form method="post" action="{{ path('app_anuncio_delete', {'id': anuncio.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');" class="btn m-0 p-0">
			<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ anuncio.id) }}">
			<button class="btn btn-light border-danger mx-1">Borrar</button>
		</form>
	</div>
	<div class="overflow-hidden relative py-3 px-2 m-5">

		<div class="row mb-4">
			<div class="col">
				<img src="{{ asset('uploads/images/' ~ anuncio.Imagen) }}" alt="{{ anuncio.Nombre }}" class="img-fluid my-2" style="max-height: 300px; object-fit: contain;">
			</div>
			<div class="col">
				<h1 class="text-4xl font-bold mb-4">{{ anuncio.Nombre }}</h1>
				<div class="rounded border border-gry p-3 mt-4">
					<h3>Detalles del Ocultos</h3>
					<p class="mx-2">
						Activo:
						<b>
							{{ anuncio.Activo ? 'Sí' : 'No' }}</b>
					</p>
				</div>
			</div>
		</div>
	</div>

	{# <div class="bg-dark py-4">
			<div class="container mx-auto px-2">
				<h1 class="text-6xl text-white text-center">
					Anuncio:
					{{ anuncio.nombre }}
				</h1>
			</div>
		</div>
	
		<div class="container mx-auto px-4 py-8">
