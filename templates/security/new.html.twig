{% extends 'base.html.twig' %}

{% block title %}New Usuario
{% endblock %}

{% block body %}
	<nav class="navbar border-bottom border-2 border-black bg-white">
		<div class="container-fluid m-3">
			<a class="logo" href="{{ path('app_index') }}">PC GAMING</a>
		</div>
	</nav>
	<main
		class="container mx-auto px-4 py-8 m-3">
		<div class="bg-white rounded shadow relative px-5 py-3 m-5 w-full md:w-1/3 border border-gry">
			{% for label, messages in app.flashes %}
				{% for message in messages %}
				<div class="alert alert-danger">
					{{ message }}
				</div>
				{% endfor %}
			{% endfor %}
			<h1 class="text-xl">Registrar Nuevo Usuario</h1>
			{{ include('security/_form.html.twig') }}
		</div>
	</main>

{% endblock %}
