{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    <label for="{{ form.Cantidad.vars.id }}">Cantidad</label>
    {{ form_widget(form.Cantidad, {'attr': {'class': 'form-control my-3'}, 'label' : 'Cantidad'}) }}
    {% if not form.Cantidad.vars.valid %}
        <div class="alert alert-danger">
            {{ form_errors(form.Cantidad) }}
        </div>
    {% endif %}
    {{ form_widget(form) }}
    
    <a class="btn btn-warning" href="{{ path('app_codigo_pedidos_show', {id: codigoPedido.id}) }}">Volver</a>
    <button class="btn btn-success">{{ button_label|default('Guardar') }}</button>
{{ form_end(form) }}
