<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}Welcome!
			{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
		{% block stylesheets %}
			{# Font Awesome CDN: provides the .fas/.fa-* icon classes used in CRUD tables. Removed SRI attribute because it caused a mismatch/block in the browser. #}
			<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
			{{ encore_entry_link_tags('app') }}
		{% endblock %}

		{% block javascripts %}
			{{ encore_entry_script_tags('app') }}
		{% endblock %}
		<style>
			.num_carro {
				color: rgb(223, 141, 18);
			}
			body {
				min-height: 100vh;
			}
			.descuento{
				background-color: red;
				width: 3.5rem;
				font-size: 1.3rem;
				font-weight: bold;
				color: white;
			}
			.precio {
				color: rgb(48, 123, 59);
				font-weight: bold;
				font-size: 1.3rem;
			}
			.logo {
				text-decoration: none;
				color: black;
				font-size: 1.5em;
				font-weight: bold;
			}
			.border-gry {
				border-color: rgb(220, 220, 220);
			}
			.destacado-bg {
				background-color: rgb(0, 157, 213);
			}
			.destacado-bg h2 {
				color: white;
				font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
			}
			.codigo-pedido-card {
				min-height: 170px;
				transition: transform 0.15s ease, box-shadow 0.15s ease;
			}
			.codigo-pedido-card:hover {
				transform: translateY(-3px);
				box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.08);
			}
			.codigo-pedido-card h4,
			.codigo-pedido-card p,
			.codigo-pedido-card h5 {
				margin-bottom: 0.75rem;
			}
			.pedido-item-card {
				min-height: 240px;
				transition: transform 0.15s ease, box-shadow 0.15s ease;
			}
			.pedido-item-card:hover {
				transform: translateY(-3px);
				box-shadow: 0 0.75rem 1.5rem rgba(0, 0, 0, 0.08);
			}
			.pedido-image {
				max-height: 160px;
				width: auto;
				object-fit: contain;
			}
			@media (max-width: 575.98px) {
				.codigo-pedido-card,
				.pedido-item-card {
					min-height: auto;
					padding: 1rem;
				}
				.pedido-image {
					max-height: 120px;
				}
			}
			.menu__list {
				display: none;
				list-style: none;
				position: absolute;
				background-color: white;
				border: 1px solid rgb(220, 220, 220);
				padding: 10px;
				margin-top: 5px;
				z-index: 3;
			}
			.menu__list li {
				margin-bottom: 5px;
			}
			.menu__list li a {
				text-decoration: none;
				color: black;
				display: block;
				padding: 5px 0;
			}
			.menu__list li a:hover {
				color: rgb(0, 157, 213);
			}

			.menu__carrito {
				display: none;
				list-style: none;
				position: absolute;
				background-color: white;
				border: 1px solid rgb(220, 220, 220);
				padding: 10px;
				margin-top: 5px;
				z-index: 3;
			}
			.menu__carrito li {
				text-decoration: none;
				margin-bottom: 5px;
			}
			.menu__carrito a {
				text-decoration: none;
				color: black;
				padding: 5px 0;
			}
			.menu__carrito a:hover {
				color: rgb(0, 157, 213);
			}

			.menu__sesion {
				display: none;
				list-style: none;
				position: absolute;
				background-color: white;
				border: 1px solid rgb(220, 220, 220);
				padding: 10px;
				margin-top: 5px;
				z-index: 3;
			}
			.menu__sesion li {
				text-decoration: none;
				margin-bottom: 5px;
				z-index: 3;
			}
			.menu__sesion a {
				text-decoration: none;
				color: black;
				padding: 5px 0;
			}
			.menu__sesion a:hover {
				color: rgb(0, 157, 213);
			}
			.menu__sesion .logout__sesion:hover {
				color: rgb(211, 21, 21);
			}

			.button_menu:hover {
				background-color: rgb(231, 231, 231);
			}
			.product-card {
				min-height: 100%;
				transition: transform 0.15s ease, box-shadow 0.15s ease;
			}
			.product-card:hover {
				transform: translateY(-2px);
				box-shadow: 0 0.75rem 1.25rem rgba(0, 0, 0, 0.08);
			}
			.product-card h4,
			.product-card p,
			.product-card h5 {
				margin-bottom: 0.75rem;
			}
			.product-image {
				max-height: 150px;
				width: 100%;
				object-fit: contain;
			}
			@media (max-width: 767.98px) {
				.product-card {
					padding: 1.25rem;
				}
				.product-image {
					max-height: 120px;
				}
			}
			footer {
				margin-top: auto;
			}
		</style>
	</head>
	<body class="bg-white d-flex flex-column min-vh-100" data-turbo="false"> 
		{% block body %}{% endblock %}
		<div id="cookieModal" class="d-none position-fixed bottom-0 start-0 text-black bg-white p-4 shadow-lg rounded m-3" style="z-index: 9999; max-width: 400px;">
			<div>
				<p class="fw-bold">Sitio de Cookies</p>
			</div>
			<hr>
			<div class="mb-3">
				Este sitio web utiliza cookies para ofrecer una mejor experiencia de usuario y permitirle inscribirse en nuestro 
				programa de bienestar en línea, de forma sencilla y en pocos pasos. No vendemos ni compartimos sus datos bajo ninguna circunstancia.
			</div>
			<div>
				<button id="cookieConsentButton" type="button" class="btn btn-primary fw-bold w-100">Aceptar</button>
			</div>
		</div>
	</body>
	<script>
		document.addEventListener('DOMContentLoaded', function() {
			const cookieModal = document.getElementById('cookieModal');
			const cookieConsentButton = document.getElementById('cookieConsentButton');

			function hasCookie(name) {
				return document.cookie.split('; ').some(cookie => cookie.startsWith(name + '='));
			}

			if (!hasCookie('cookieConsent')) {
				cookieModal.classList.remove('d-none');
			}

			cookieConsentButton.addEventListener('click', function() {
				const expires = new Date();
				expires.setFullYear(expires.getFullYear() + 1);
				document.cookie = 'cookieConsent=true; expires=' + expires.toUTCString() + '; path=/; SameSite=Lax';
				cookieModal.classList.add('d-none');
			});
		});
	</script>
	</html>
