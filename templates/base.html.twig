<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
            {# Font Awesome CDN: provides the .fas/.fa-* icon classes used in CRUD tables. Removed SRI attribute because it caused a mismatch/block in the browser. #}
            <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
                {{ encore_entry_script_tags('app') }}
        {% endblock %}
        <style>
            .num_carro{
                color: rgb(223, 141, 18);
            }
            body{
                min-height: 100vh;
            }
            .precio {
                color: rgb(48, 123, 59);
                font-weight: bold;
            }
            .logo{
                text-decoration: none;
                color: black;
                font-size: 1.5em;
                font-weight: bold;
            }
            .border-gry{
                border-color: rgb(220, 220, 220);
            }
            .destacado-bg{
                background-color: rgb(0, 157, 213);
            }
            .destacado-bg h2{
                color: white;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }
            .menu__list{
                display: none;
                list-style: none;
                position: absolute;
                background-color: white;
                border: 1px solid rgb(220, 220, 220);
                padding: 10px;
                margin-top: 5px;
            }
             .menu__list li{
                margin-bottom: 5px;
            }
             .menu__list li a{
                text-decoration: none;
                color: black;
                display: block;
                padding: 5px 0;
            }
             .menu__list li a:hover{
                color: rgb(0, 157, 213);
            }

            .menu__carrito{
                display: none;
                list-style: none;
                position: absolute;
                background-color: white;
                border: 1px solid rgb(220, 220, 220);
                padding: 10px;
                margin-top: 5px;
            }
             .menu__carrito li{
                text-decoration: none;
                margin-bottom: 5px;
            }
             .menu__carrito a{
                text-decoration: none;
                color: black;
                padding: 5px 0;
            }
             .menu__carrito a:hover{
                color: rgb(0, 157, 213);
            }

            .button_menu:hover{
                background-color: rgb(231, 231, 231);
            }
            footer{
                margin-top: auto;
            }
        </style>

    </head>
    <body class="bg-white d-flex flex-column min-vh-100">
        {% block body %}{% endblock %}
    </body>
</html>
