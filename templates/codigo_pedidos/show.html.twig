{% extends 'base.html.twig' %}

{% block title %}Info. de Codigo Pedido: {{ codigo_pedido.codigo }}
{% endblock %}

{% block body %}
	{% include 'partials/navbar.html.twig' %}
	{% include 'partials/script_borrar.html.twig' %}
	
	<main class="container py-4">
		{% for label, messages in app.flashes %}
			{% for message in messages %}
				<div class="alert alert-info mx-2 my-3">
					{{ message }}
				</div>
			{% endfor %}
		{% endfor %}
		<div class="mb-4 d-flex flex-column flex-sm-row flex-wrap gap-2 align-items-start mx-4">
			<a href="{{ path('app_codigo_pedidos_index') }}" class="btn btn-light border-black mx-1">
				Volver
			</a>
			<a href="{{ path('app_codigo_pedidos_edit', {id: codigo_pedido.id}) }}" class="btn btn-light border-info">
				Editar
			</a>
			<div class="position-relative" id="borrarCelda">
				<button type="button" class="btn btn-light border-danger" id="borrarCeldaToggle">
	            	<span>Borrar</span>
				</button>
				<div class="rounded border border-gry p-3 borrarCelda d-none position-absolute start-0 mt-2 bg-white shadow-sm" style="z-index: 10; min-width: 220px;">
					<p class="mx-2"> Estas seguro de borrar este elemento</p>
					<form method="post" action="{{ path('app_codigo_pedidos_delete', {'id': codigo_pedido.id}) }}" class="m-0 p-0">
						<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ codigo_pedido.id) }}">
						<button class="btn btn-light border-danger mx-1">Estoy Seguro</button>
					</form> 
				</div>
			</div>
		</div>
		<div class="row gx-4 gy-4">
			<div class="col-12 col-lg-4">
				<div class="card h-100 border-gry shadow-sm p-4">
					<h1 class="h4 fw-bold mb-3">Código de Pedido</h1>
					<p class="mb-2"><strong>Pedido:</strong> {{ codigo_pedido.codigo }}</p>
					<p class="mb-2 text-secondary"><strong>Fecha de compra:</strong> {{ codigo_pedido.fecha.format('d-m-Y') }}</p>
					<p class="mb-2"><strong>Estado:</strong> <span class="precio">{{ codigo_pedido.estado == 0 ? 'Preparando' : codigo_pedido.estado == 1 ? 'En Reparto' : 'Enviado' }}</span></p>
					<p class="mb-0"><strong>Cliente:</strong> {{ codigo_pedido.Cliente.Nombre }} {{ codigo_pedido.Cliente.Apellidos }}</p>
				</div>
			</div>
			<div class="col-12 col-lg-8">
				<div class="card border-gry shadow-sm p-3">
					<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-3">
						<h2 class="h5 mb-0">Productos del pedido</h2>
						<a href="{{ path('app_pedidos_new', {id: codigo_pedido.id}) }}" class="btn btn-primary btn-sm">Add One +</a>
					</div>
					<div class="row g-3">
						{% if pedidos is empty %}
							<div class="col-12">
								<div class="card h-100 border-gry shadow-sm p-4 text-center">
									<p class="mb-0">No hay productos en el pedido.</p>
								</div>
							</div>
						{% else %}
							{% for pedido in pedidos %}
								<div class="col-12 col-sm-6 col-md-4">
									<a href="{{ path('app_pedidos_show', {id: pedido.id}) }}" class="text-decoration-none d-block h-100">
										<div class="pedido-item-card card h-100 border-gry shadow-sm p-3 text-center">
											<h4 class="h6 mb-2 text-dark">{{ pedido.Producto.Nombre }}</h4>
											<img src="{{ asset('uploads/images/' ~ pedido.Producto.Imagen) }}" alt="{{ pedido.Producto.Nombre }}" class="img-fluid mb-3 pedido-image" loading="lazy">
											<p class="mb-1">Cantidad: <strong>{{ pedido.Cantidad }}</strong></p>
										</div>
									</a>
								</div>
							{% endfor %}
						{% endif %}
					</div>
				</div>
			</div>
		</div>
	</main>
	{% include 'partials/footer.html.twig' %}
{% endblock %}
