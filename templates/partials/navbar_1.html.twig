<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom border-2 border-black">
    <div class="container-fluid">
        <a class="navbar-brand logo" href="{{ path('app_homepage') }}">PC GAMING</a>

        <button class="navbar-toggler order-2" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="d-flex align-items-center gap-3 ms-auto order-3">
            <div class="nav-item dropdown" id="dropbox-carrito">
                <button class="btn btn-link position-relative p-0" id="carritoDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <img src="https://cdn-icons-png.flaticon.com/512/287/287581.png" alt="Carrito" class="img-fluid" style="max-width: 20px;">
                    {% if carro_num > 0 %}
                        <span class="badge bg-warning text-dark rounded-pill position-absolute top-0 start-100 translate-middle">{{ carro_num }}</span>
                    {% endif %}
                </button>
                <ul class="dropdown-menu dropdown-menu-end p-2" aria-labelledby="carritoDropdown">
                    {% for carro in carritos|slice(0, 2) %}
                        <li class="border-bottom pb-2 mb-2">
                            <p class="mb-1">{{ carro.Producto.Nombre }}</p>
                            <p class="mb-0 small">Cantidad: {{ carro.Cantidad }} · {{ carro.Producto.Precio }}€</p>
                        </li>
                    {% endfor %}
                    {% if carro_num > 2 %}
                        <li class="border-bottom pb-2 mb-2">Y más...</li>
                    {% endif %}
                    <li><a class="dropdown-item px-0" href="{{ path('carrito_online') }}">Ver Carrito</a></li>
                </ul>
            </div>

            <div class="nav-item dropdown" id="dropbox-sesion">
                <button class="btn btn-link nav-link dropdown-toggle d-flex align-items-center p-0" id="sesionDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <img src="https://cdn-icons-png.flaticon.com/512/1077/1077114.png" alt="Icono_Usuario" class="img-fluid" style="max-width: 20px;">
                    <span class="ms-2"><b class="font-weight-bold">{{ app.user.Nombre }} {{ app.user.Apellidos|slice(0,1) }}.</b></span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="sesionDropdown">
                    {% if mostrarBoton %}
                        <li><a class="dropdown-item" href="{{ path('app_index_crud') }}">Base de Datos</a></li>
                    {% endif %}
                    <li><a class="dropdown-item" href="{{ path('app_cuenta') }}">Tu Cuenta</a></li>
                    <li><a class="dropdown-item" href="{{ path('pedidos_online') }}">Tus Pedidos</a></li>
                    <li><a class="dropdown-item text-danger" href="{{ path('app_logout') }}">Cerrar sesión</a></li>
                </ul>
            </div>
        </div>

        <div class="collapse navbar-collapse order-4 order-lg-2" id="mainNavbar">
            <div class="d-flex flex-wrap align-items-center gap-2 w-100">
                <div class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle p-0" href="#" id="categoriasDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <span class="ms-1">Categorias</span>
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="categoriasDropdown">
                        {% for categoria in categorias %}
                            <li><a class="dropdown-item" href="{{ path('categoria_online', {id: categoria.id}) }}">{{ categoria.Nombre }}</a></li>
                        {% endfor %}
                    </ul>
                </div>

                <div class="flex-grow-1">
                    {{ include('partials/_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
</nav>