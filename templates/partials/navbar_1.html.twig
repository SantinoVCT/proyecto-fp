<nav class="navbar border-bottom border-2 border-black bg-white">
	<div class="container-fluid">
		<div class="m-3">
			<a class="logo" href="{{ path('app_homepage') }}">PC GAMING</a>
		</div>
		<div class="m-3 text-black">
			<h6 class="fw-normal m-0"> Bienvenido, <b class="font-weight-bold" >{{ app.user.Nombre }} {{ app.user.Apellidos }} </b> </h6>
		</div>
		<div class="m-2 mx-5" id="dropbox-categorias">
			<button class="m-0 border-0 btn button_menu ">
				<img src="https://img.icons8.com/?size=100&id=120374&format=png&color=000000" alt="Categorias" style="width: 20px; height: 20px;">
            	<span>Categorias</span>
			</button>
			<ul class="menu__list">
				{% for categoria in categorias %}
					<li><a href="{{ path('categoria_online', {id: categoria.id}) }}" class="">{{ categoria.Nombre }}</a></li>
				{% endfor %}
			</ul>
		</div>
        <div class="flex-grow-1 m-2 mx-5">
            {{ include('partials/_form.html.twig') }}
        </div>
		<div class="m-3 d-flex">
			<div class="my-2 mx-0" id="dropbox-carrito">
				<button class="btn btn-light border-black">
					<img src="https://cdn-icons-png.flaticon.com/512/287/287581.png" alt="Carrito" class="img-fluid m-0 p-0" style="max-width: 20px"> 
					{% if carro_num > 0 %}
						<b class="num_carro">{{ carro_num }}</b>
					{% endif %}
				</button>
				<ul class="menu__carrito">	
					{% for carro in carritos|slice(0, 3) %}
						<li class="border-bottom">
							<p>{{ carro.Producto.Nombre }}</p>
							<p>Cantida: {{ carro.Cantidad }} Precio: {{carro.Producto.Precio}}</p>
						</li>
					{% endfor %}
					{% if carro_num > 3 %}
						<li class="border-bottom">Y más...</li>
					{% endif %}
					<a href="{{ path('carrito_online', {idUser: app.user.id}) }}  class="btn btn-light border-black"">Ver Carrito</a>
				</ul>
			</div>
		</div>
		
		<div class="mx-2" id="dropbox-sesion">
			<button class="m-0 border-0 btn button_menu ">
				<img src="https://cdn-icons-png.flaticon.com/512/1077/1077114.png" alt="Icono_Usuario" class="img-fluid m-0 p-0" style="max-width: 20px">
            	<span><b class="font-weight-bold" >{{ app.user.Nombre }} {{ app.user.Apellidos }} </b></span>
			</button>
			<ul class="menu__sesion">
				{% if mostrarBoton %}
					<li class="border-bottom">
						<a href="{{ path('app_index_crud') }}" class="">Base de Datos</a>
					</li>
				{% endif %}
				<li class="border-bottom"><a href="{{ path('pedidos_online') }}" class="">Tus Pedidos</a></li>
				<li><a href="{{ path('app_logout') }}" class="logout__sesion">Cerrar sesión</a></li>
			</ul>
		</div>
	</div>
</nav>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const dropbox = document.getElementById('dropbox-categorias');
        const dropbox_2 = document.getElementById('dropbox-carrito');

        const menuList = dropbox.querySelector('.menu__list');
        const menuList_2 = dropbox_2.querySelector('.menu__carrito');

		const dropbox_3 = document.getElementById('dropbox-sesion');
        const menuList_3 = dropbox_3.querySelector('.menu__sesion');
        
		dropbox.addEventListener('click', function(event) {
            event.stopPropagation();
            menuList_3.style.display = 'none';
            menuList_2.style.display = 'none';

            menuList.style.display = menuList.style.display === 'block' ? 'none' : 'block';
        });
		dropbox_2.addEventListener('click', function(event) {
            event.stopPropagation();
            menuList.style.display = 'none';
            menuList_3.style.display = 'none';

            menuList_2.style.display = menuList_2.style.display === 'block' ? 'none' : 'block';
        });
		dropbox_3.addEventListener('click', function(event) {
            event.stopPropagation();
            menuList.style.display = 'none';
            menuList_2.style.display = 'none';

            menuList_3.style.display = menuList_3.style.display === 'block' ? 'none' : 'block';
        });


        document.addEventListener('click', function() {
            menuList.style.display = 'none';
            menuList_2.style.display = 'none';
            menuList_3.style.display = 'none';
        });
    });

</script>