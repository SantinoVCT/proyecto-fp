<script>
    // Seleccionamos los elementos
    const abrirBtn = document.getElementById('abrir-btn');
    const cerrarBtn = document.getElementById('cerrar-btn');
    const sidebar = document.getElementById('mi-sidebar');
    const overlay = document.getElementById('overlay');

    // Función para abrir el sidebar
    function abrirSidebar() {
        sidebar.classList.add('activo');
        overlay.classList.add('activo');
    }

    // Función para cerrar el sidebar
    function cerrarSidebar() {
        sidebar.classList.remove('activo');
        overlay.classList.remove('activo');
    }

    // Eventos de clic
    abrirBtn.addEventListener('click', abrirSidebar);
    cerrarBtn.addEventListener('click', cerrarSidebar);

    // Opcional: Cerrar al hacer clic en el overlay (fondo oscuro)
    overlay.addEventListener('click', cerrarSidebar);
</script>

<style>
	/* --- Sidebar --- */
	.sidebar {
	    height: 100%;
	    width: 0;
	    position: fixed;
	    z-index: 1000;
	    top: 0;
	    left: 0;
	    background-color: #111;
	    overflow-x: hidden;
	    transition: 0.3s; /* Efecto de deslizamiento */
	    padding-top: 60px;
        &::-webkit-scrollbar {
            display: none;
        }
	}
	
	.sidebar a {
	    padding: 15px 25px;
        color: #818181;
	    text-decoration: none;
	    font-size: 25px;
	    color: #818181;
	    display: block;
	    transition: 0.3s;
	}
	
	.sidebar a:hover {
	    color: #f1f1f1;
	}
	
	.sidebar .boton-cerrar {
	    position: absolute;
	    top: 20px;
	    right: 25px;
	    font-size: 36px;
	    background: none;
	    border: none;
	    color: #818181;
	    cursor: pointer;
	}
	
	/* --- Overlay (Fondo oscuro) --- */
	.overlay {
	    display: none;
	    position: fixed;
	    width: 100%;
	    height: 100%;
	    top: 0;
	    left: 0;
	    background-color: rgba(0,0,0,0.5);
	    z-index: 999;
	}
	
	/* --- Clases activas (JavaScript las añadirá) --- */
	.sidebar.activo {
	    width: 250px; /* Ancho del sidebar al abrirse */
	}
	
	.overlay.activo {
	    display: block;
	}
</style>